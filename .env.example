# NexusAgent Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================
# LOCAL MODEL SETTINGS (Default - Offline Mode)
# ============================================================
# Path to directory containing GGUF model files
NEXUS_MODELS_DIR=~/models

# Default model filename (within NEXUS_MODELS_DIR)
NEXUS_DEFAULT_MODEL=

# Number of GPU layers to offload (-1 = all, 0 = CPU only)
NEXUS_GPU_LAYERS=-1

# Context window size (tokens)
NEXUS_CONTEXT_SIZE=4096

# Number of CPU threads for inference
NEXUS_THREADS=0

# LLM Runtime backend: auto, llama-cpp, onnx
NEXUS_RUNTIME=auto

# Reasoning effort level: low, medium, high, xhigh, max
NEXUS_EFFORT_LEVEL=medium

# ============================================================
# CLOUD PROVIDER API KEYS (Optional)
# ============================================================
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=

# AWS Bedrock (optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# Custom OpenAI-compatible endpoint
CUSTOM_PROVIDER_BASE_URL=
CUSTOM_PROVIDER_API_KEY=
CUSTOM_PROVIDER_MODEL=

# ============================================================
# OLLAMA SETTINGS (Optional local server)
# ============================================================
OLLAMA_BASE_URL=http://localhost:11434

# ============================================================
# GUI SETTINGS
# ============================================================
NEXUS_GUI_HOST=127.0.0.1
NEXUS_GUI_PORT=7860

# ============================================================
# AGENT SETTINGS
# ============================================================
# Permission mode: suggest, ask, auto
NEXUS_PERMISSION_MODE=ask

# Data directory for sessions, memory, etc.
NEXUS_DATA_DIR=~/.nexus-agent
